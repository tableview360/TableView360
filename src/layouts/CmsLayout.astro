---
import '../styles/global.css';

interface Props {
  title?: string;
  active?: string;
}

const { title = 'CMS - TableView360', active = '' } = Astro.props;

const navItems = [
  { href: '/cms', label: 'Dashboard', icon: '📊', id: 'dashboard' },
  {
    href: '/cms/restaurantes',
    label: 'Restaurantes',
    icon: '🍽️',
    id: 'restaurantes',
  },
  { href: '/cms/clientes', label: 'Clientes', icon: '👥', id: 'clientes' },
  { href: '/cms/reservas', label: 'Reservas', icon: '📅', id: 'reservas' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-slate-100 antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 border-r border-slate-700/50 bg-slate-800/90">
        <div class="flex h-16 items-center border-b border-slate-700/50 px-6">
          <a href="/cms" class="text-lg font-bold text-slate-100">
            <span class="text-violet-400">CMS</span> Admin
          </a>
        </div>
        <nav class="p-4 space-y-1">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class={`flex items-center gap-3 rounded-lg px-4 py-2.5 text-sm font-medium transition ${
                  active === item.id
                    ? 'bg-violet-500/10 text-violet-400'
                    : 'text-slate-400 hover:bg-slate-900 hover:text-slate-100'
                }`}
              >
                <span>{item.icon}</span>
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="absolute bottom-0 w-64 border-t border-slate-700/50 p-4">
          <a
            href="/"
            class="flex items-center gap-2 text-sm text-slate-500 hover:text-slate-300"
          >
            &larr; Volver al sitio
          </a>
          <button
            id="cms-logout-btn"
            class="mt-2 flex w-full items-center gap-2 text-sm text-red-400 hover:text-red-400"
          >
            Cerrar Sesión
          </button>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1">
        <header
          class="flex h-16 items-center border-b border-slate-700/50 bg-slate-800/90 px-8"
        >
          <h1 class="text-lg font-semibold text-slate-100">{title}</h1>
        </header>
        <main class="p-8">
          <slot />
        </main>
      </div>
    </div>

    <script>
      document
        .getElementById('cms-logout-btn')
        ?.addEventListener('click', async () => {
          await fetch('/api/auth/logout', { method: 'POST' });
          window.location.href = '/';
        });
    </script>
  </body>
</html>
