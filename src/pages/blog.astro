---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/footer/footer';
import { t, type LangCode } from '../lib/i18n';

const lang = (Astro.locals.lang || 'en') as LangCode;
---

<Layout title={`${t('footer.nav.blog', lang)} - TableView360`}>
  <div class="min-h-screen flex flex-col">
    <Navbar client:load user={false} role={null} lang={lang} />

    <main class="flex-1 mx-auto max-w-4xl px-6 pt-28 pb-16">
      <h1 class="text-4xl font-bold text-slate-50 mb-4 text-center">
        {t('footer.nav.blog', lang)}
      </h1>
      <p class="text-slate-400 text-center text-lg mb-12">
        {t('blog.subtitle', lang)}
      </p>

      <div class="flex flex-col items-center gap-6 py-16">
        <div
          class="w-16 h-16 rounded-2xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-3xl"
        >
          ✍️
        </div>
        <p class="text-slate-500 text-center max-w-md">
          {t('blog.comingSoon', lang)}
        </p>
      </div>
    </main>

    <Footer client:load lang={lang} />
  </div>
</Layout>
