---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/footer/footer';
import ContactForm from '../components/forms/ContactForm';
import { t, type LangCode } from '../lib/i18n';

const lang = (Astro.locals.lang || 'en') as LangCode;
---

<Layout title={`${t('Contact Us', lang)} - TableView360`}>
  <div class="min-h-screen flex flex-col">
    <Navbar client:load user={false} role={null} lang={lang} />

    <main class="flex-1 mx-auto max-w-7xl px-6 pt-28 pb-16">
      <h1 class="text-4xl font-bold text-slate-50 mb-12 text-center">
        {t('Contact Us', lang)}
      </h1>

      <ContactForm client:load />
    </main>

    <Footer client:load lang={lang} />
  </div>
</Layout>
