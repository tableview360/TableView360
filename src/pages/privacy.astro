---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/footer/footer';
import { t, type LangCode } from '../lib/i18n';

const lang = (Astro.locals.lang || 'en') as LangCode;
---

<Layout title={`${t('Privacy / GDPR', lang)} - TableView360`}>
  <div class="min-h-screen flex flex-col">
    <Navbar client:load user={false} role={null} lang={lang} />

    <main class="flex-1 mx-auto max-w-4xl px-6 pt-28 pb-16">
      <h1 class="text-4xl font-bold text-slate-50 mb-12 text-center">
        {t('Privacy / GDPR', lang)}
      </h1>

      <div
        class="prose prose-invert prose-slate max-w-none space-y-8 text-slate-400 leading-relaxed"
      >
        <section>
          <h2 class="text-xl font-semibold text-slate-200 mb-3">
            {t('privacy.section1_title', lang)}
          </h2>
          <p>{t('privacy.section1_body', lang)}</p>
        </section>
        <section>
          <h2 class="text-xl font-semibold text-slate-200 mb-3">
            {t('privacy.section2_title', lang)}
          </h2>
          <p>{t('privacy.section2_body', lang)}</p>
        </section>
        <section>
          <h2 class="text-xl font-semibold text-slate-200 mb-3">
            {t('privacy.section3_title', lang)}
          </h2>
          <p>{t('privacy.section3_body', lang)}</p>
        </section>
      </div>
    </main>

    <Footer client:load lang={lang} />
  </div>
</Layout>
