---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import { createSupabaseServer } from '../../lib/supabase';
import { type LangCode } from '../../lib/i18n';

const lang = (Astro.locals.lang || 'en') as LangCode;
const supabase = createSupabaseServer(Astro.cookies, Astro.request);
const role = Astro.locals.role;
const user = Astro.locals.user;

// Fetch user profile for username display
let username: string | null = null;
let avatarUrl: string | null = null;
if (user) {
  const { data: profile } = await supabase
    .from('profiles')
    .select('username, full_name, avatar_url')
    .eq('id', user.id)
    .maybeSingle();
  username = profile?.username || profile?.full_name || null;
  avatarUrl = profile?.avatar_url ?? null;
}

const { data: restaurants, error: restaurantsError } = await supabase
  .from('restaurants')
  .select('id, name, slug, description, address, logo_url, phone')
  .order('created_at', { ascending: false });

if (restaurantsError) {
  console.error('[restaurantes] query error:', restaurantsError.message);
}
---

<Layout title="Restaurantes - TableView360">
  <div class="min-h-screen">
    <Navbar
      client:load
      user={!!user}
      role={role}
      lang={lang}
      username={username}
      avatarUrl={avatarUrl}
    />

    <main class="mx-auto max-w-7xl px-6 pt-24 pb-10">
      <h1 class="text-3xl font-bold text-slate-100">Restaurantes</h1>
      <p class="mt-2 text-slate-500">
        Explora y reserva en los mejores restaurantes
      </p>

      {
        restaurants && restaurants.length > 0 ? (
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {restaurants.map((r) => (
              <a
                href={`/restaurantes/${r.id}`}
                class="group block overflow-hidden rounded-2xl border border-slate-700/50 bg-slate-800/90 shadow-sm transition hover:shadow-xl"
              >
                <div class="aspect-video bg-slate-800">
                  {r.logo_url ? (
                    <img
                      src={r.logo_url}
                      alt={r.name}
                      class="h-full w-full object-cover transition group-hover:scale-105"
                    />
                  ) : (
                    <div class="flex h-full items-center justify-center text-5xl text-slate-500">
                      🍽️
                    </div>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="text-lg font-semibold text-slate-100 group-hover:text-violet-400">
                    {r.name}
                  </h3>
                  {r.address && (
                    <p class="mt-1 text-sm text-slate-500">📍 {r.address}</p>
                  )}
                  {r.description && (
                    <p class="mt-2 line-clamp-2 text-sm text-slate-400">
                      {r.description}
                    </p>
                  )}
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="mt-20 text-center text-slate-500">
            <p class="text-5xl mb-4">🍽️</p>
            <p class="text-lg">No hay restaurantes disponibles todavía</p>
          </div>
        )
      }
    </main>
  </div>
</Layout>
