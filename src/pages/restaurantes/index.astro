---
import Layout from '../../layouts/Layout.astro';
import { createSupabaseServer } from '../../lib/supabase';

const supabase = createSupabaseServer(Astro.cookies);
const user = (Astro.locals as any).user;
const role = (Astro.locals as any).role;

const { data: restaurants } = await supabase
  .from('restaurants')
  .select('id, name, description, city, cover_image, phone')
  .order('created_at', { ascending: false });
---

<Layout title="Restaurantes - TableView360">
  <div class="min-h-screen">
    <!-- Navbar -->
    <nav class="border-b border-slate-700/50 bg-slate-800/90 px-6 py-4">
      <div class="mx-auto flex max-w-7xl items-center justify-between">
        <a href="/" class="text-xl font-bold text-slate-100">TableView360</a>
        <div class="flex items-center gap-4">
          {role === 'admin' && (
            <a href="/cms" class="text-sm font-medium text-slate-400 hover:text-slate-100">CMS Admin</a>
          )}
          {role === 'restaurant' && (
            <a href="/dashboard" class="text-sm font-medium text-slate-400 hover:text-slate-100">Mi Panel</a>
          )}
          <a href="/restaurantes" class="text-sm font-medium text-violet-400">Restaurantes</a>
          <button
            id="logout-btn"
            class="rounded-lg bg-slate-800 px-4 py-2 text-sm font-medium text-slate-300 transition hover:bg-slate-600"
          >
            Cerrar Sesión
          </button>
        </div>
      </div>
    </nav>

    <main class="mx-auto max-w-7xl px-6 py-10">
      <h1 class="text-3xl font-bold text-slate-100">Restaurantes</h1>
      <p class="mt-2 text-slate-500">Explora y reserva en los mejores restaurantes</p>

      {restaurants && restaurants.length > 0 ? (
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {restaurants.map((r) => (
            <a
              href={`/restaurantes/${r.id}`}
              class="group block overflow-hidden rounded-2xl border border-slate-700/50 bg-slate-800/90 shadow-sm transition hover:shadow-xl"
            >
              <div class="aspect-video bg-slate-800">
                {r.cover_image ? (
                  <img src={r.cover_image} alt={r.name} class="h-full w-full object-cover transition group-hover:scale-105" />
                ) : (
                  <div class="flex h-full items-center justify-center text-5xl text-slate-500">🍽️</div>
                )}
              </div>
              <div class="p-5">
                <h3 class="text-lg font-semibold text-slate-100 group-hover:text-violet-400">{r.name}</h3>
                {r.city && <p class="mt-1 text-sm text-slate-500">📍 {r.city}</p>}
                {r.description && <p class="mt-2 line-clamp-2 text-sm text-slate-400">{r.description}</p>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="mt-20 text-center text-slate-500">
          <p class="text-5xl mb-4">🍽️</p>
          <p class="text-lg">No hay restaurantes disponibles todavía</p>
        </div>
      )}
    </main>
  </div>

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/';
    });
  </script>
</Layout>
